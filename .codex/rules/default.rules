prefix_rule(pattern = ["npm", "run", "lint"], decision = "allow")
prefix_rule(pattern = ["npm", "run", "build"], decision = "allow")
prefix_rule(pattern = ["npm", "run", "dev"], decision = "prompt", justification = "Starting the dev server is safe but long-running.")
prefix_rule(pattern = ["npx", "tsc"], decision = "allow")
prefix_rule(pattern = ["git", "diff"], decision = "allow")
prefix_rule(pattern = ["git", "status"], decision = "allow")
prefix_rule(pattern = ["git", "log"], decision = "allow")
prefix_rule(pattern = ["git", "show"], decision = "allow")

prefix_rule(pattern = ["npm", "install"], decision = "prompt", justification = "Dependency changes require review.")
prefix_rule(pattern = ["npm", "ci"], decision = "prompt", justification = "Dependency install uses network and lifecycle scripts.")
prefix_rule(pattern = ["git", "push"], decision = "prompt", justification = "Publishing branches requires human approval.")
prefix_rule(pattern = ["gh", "pr", "create"], decision = "prompt", justification = "Draft PR creation is the human review gate.")
prefix_rule(pattern = ["gh", "pr", "merge"], decision = "forbidden", justification = "Humans merge PRs.")
prefix_rule(pattern = ["vercel", "deploy"], decision = "forbidden", justification = "Humans deploy.")
prefix_rule(pattern = ["vercel", "--prod"], decision = "forbidden", justification = "Humans deploy production.")
prefix_rule(pattern = ["rm"], decision = "prompt", justification = "Deletion requires review.")
