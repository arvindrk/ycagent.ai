{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/agent/init.sh\"",
            "timeout": 30,
            "statusMessage": "Loading ycagent.ai agent state"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/stop-state-check.sh\"",
            "timeout": 30,
            "statusMessage": "Checking agent tracker state"
          }
        ]
      }
    ]
  }
}
